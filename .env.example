DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

WORKSPACE_NAME=Runner Challenger
TIMEZONE=Australia/Sydney
DATA_FILE=.tmp/runner-challenger.json
REGISTER_COMMANDS=true

# Optional channel ids. Names are fine for local storage, but ids are better once
# scheduled posting is added.
DISCORD_RULES_CHANNEL_ID=
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=
DISCORD_PROGRESS_LOG_CHANNEL_ID=
DISCORD_LEADERBOARD_CHANNEL_ID=
DISCORD_CHAT_CHANNEL_ID=
DISCORD_COMBINED_CHANNEL_ID=

# Optional Strava integration.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback
STRAVA_STATE_SECRET=
PORT=3000
